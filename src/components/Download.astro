---
import { LINKS, RELEASE } from '../config';

const windowsHref = RELEASE.windowsExe || LINKS.GITHUB_RELEASES_URL;
const macHref = RELEASE.macDmg || LINKS.GITHUB_RELEASES_URL;
const androidHref = RELEASE.androidApk || LINKS.GITHUB_RELEASES_URL;
const iosHref = RELEASE.iosZip || LINKS.GITHUB_RELEASES_URL;
---

<section id="indir" class="relative py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2
        class="reveal text-3xl font-extrabold tracking-tight text-ink-bright sm:text-4xl"
      >
        Staple’ı indir
      </h2>
      <p class="reveal mt-4 text-lg text-ink">
        Masaüstü uygulamalarıyla hızlıca bağlan ya da tarayıcıdan anında başla.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      <!-- Windows kartı (öne çıkan) -->
      <article
        class="reveal relative flex flex-col rounded-2xl border border-gold/40 bg-secondary p-8 lg:col-span-1"
      >
        <div
          class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary text-gold"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-6 w-6"
            aria-hidden="true"
          >
            <path
              d="M3 5.5 10.5 4.4v7.1H3V5.5Zm0 13 7.5 1.1v-7H3v5.9Zm8.5 1.2L21 21V12.5h-9.5v7.2Zm0-15.4V11.5H21V3l-9.5 1.3Z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-extrabold text-ink-bright">Windows</h3>
        <p class="mt-2 text-sm text-ink">
          <span class="latest-version">{RELEASE.version}</span> · {RELEASE.sizeWindows} · Windows 10/11
        </p>

        <div class="mt-6 flex flex-col gap-3">
          <a
            href={windowsHref}
            download
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-gold px-5 py-3 text-base font-bold text-primary transition-colors hover:bg-gold-soft"
          >
            .exe indir
          </a>
        </div>
        <a
          href={LINKS.GITHUB_RELEASES_URL}
          target="_blank"
          rel="noopener"
          class="mt-4 text-center text-xs text-ink/70 underline-offset-2 hover:text-gold hover:underline"
          >Tüm sürümler (GitHub Releases)</a
        >
      </article>

      <!-- Web kartı -->
      <article
        class="reveal flex flex-col rounded-2xl border border-white/5 bg-secondary p-8"
      >
        <div
          class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary text-gold"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-6 w-6"
            aria-hidden="true"
          >
            <path
              d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm6.9 6h-2.6a15.6 15.6 0 0 0-1.2-3.3A8 8 0 0 1 18.9 8ZM12 4c.7 1 1.3 2.4 1.7 4h-3.4c.4-1.6 1-3 1.7-4ZM4.3 14A8 8 0 0 1 4 12c0-.7.1-1.4.3-2h3a17.6 17.6 0 0 0 0 4h-3Zm.8 2h2.6c.3 1.2.7 2.3 1.2 3.3A8 8 0 0 1 5.1 16Zm2.6-8H5.1a8 8 0 0 1 3.8-3.3C8.4 5.7 8 6.8 7.7 8ZM12 20c-.7-1-1.3-2.4-1.7-4h3.4c-.4 1.6-1 3-1.7 4Zm2.1-6H9.9a15.4 15.4 0 0 1 0-4h4.2a15.4 15.4 0 0 1 0 4Zm.8 5.3c.5-1 .9-2.1 1.2-3.3h2.6a8 8 0 0 1-3.8 3.3ZM17 14a17.6 17.6 0 0 0 0-4h3c.2.6.3 1.3.3 2s-.1 1.4-.3 2h-3Z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-extrabold text-ink-bright">Web sürümü</h3>
        <p class="mt-2 text-sm text-ink">
          Kurulum yok — tarayıcından anında aç ve bağlan.
        </p>
        <a
          href={LINKS.WEB_APP_URL}
          target="_blank"
          rel="noopener"
          class="mt-auto inline-flex items-center justify-center gap-2 rounded-xl bg-gold px-5 py-3 text-base font-bold text-primary transition-colors hover:bg-gold-soft"
        >
          Web’de Aç
        </a>
      </article>

      <!-- macOS kartı -->
      <article
        class="reveal flex flex-col rounded-2xl border border-white/5 bg-secondary p-8"
      >
        <div
          class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary text-gold"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-6 w-6"
            aria-hidden="true"
          >
            <path
              d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C3.8 16.32 3.1 9.88 7.02 5.92c.98-.98 2.15-1 3.03-.52 1.05.57 1.84.5 2.87 0 .84-.4 2.15-.55 3.1.4 1.25.9 2.05 2.2 2.45 3.97-2.6 1.1-2.2 4.63.4 5.75-.5 1.5-1.23 3.32-2.82 4.76M12.03 5.4c.12-2.26 1.88-4.22 3.98-4.4.24 2.4-1.92 4.62-3.98 4.4"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-extrabold text-ink-bright">macOS</h3>
        <p class="mt-2 text-sm text-ink">
          <span class="latest-version">{RELEASE.version}</span> · {RELEASE.sizeMac} · macOS (Apple/Intel)
        </p>

        <div class="mt-6 flex flex-col gap-3">
          <a
            href={macHref}
            download
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-gold px-5 py-3 text-base font-bold text-primary transition-colors hover:bg-gold-soft"
          >
            .dmg indir
          </a>
        </div>
        <a
          href={LINKS.GITHUB_RELEASES_URL}
          target="_blank"
          rel="noopener"
          class="mt-4 text-center text-xs text-ink/70 underline-offset-2 hover:text-gold hover:underline"
          >Tüm sürümler (GitHub Releases)</a
        >
      </article>
    </div>

    <!-- Mobil Sürümler -->
    <div class="mt-20 text-center">
      <h3
        class="reveal text-2xl font-extrabold tracking-tight text-ink-bright sm:text-3xl"
      >
        Mobil Sürümler
      </h3>
      <p class="reveal mt-4 text-sm text-ink">
        Topluluğuna mobilden de bağlı kal. Son versiyonları doğrudan indir.
      </p>
    </div>

    <div class="mt-10 grid gap-6 max-w-4xl mx-auto md:grid-cols-2">
      <!-- Android kartı -->
      <article
        class="reveal flex flex-col rounded-2xl border border-white/5 bg-secondary p-8"
      >
        <div
          class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary text-gold"
        >
          <!-- Android SVG Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-6 w-6"
            aria-hidden="true"
          >
            <path
              d="M12 2c.28 0 .5.22.5.5V5h4c2.2 0 4 1.8 4 4v9c0 2.2-1.8 4-4 4H7.5c-2.2 0-4-1.8-4-4V9c0-2.2 1.8-4 4-4h4V2.5c0-.28.22-.5.5-.5Zm-5 7c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1Zm10 0c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1Z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-extrabold text-ink-bright">Android</h3>
        <p class="mt-2 text-sm text-ink">
          Android cihazlar için derlenmiş resmi kurulum paketi.
        </p>

        <div class="mt-6 flex flex-col gap-3">
          <a
            href={androidHref}
            download
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-gold px-5 py-3 text-base font-bold text-primary transition-colors hover:bg-gold-soft"
          >
            .apk indir
          </a>
        </div>
        <a
          href={LINKS.GITHUB_RELEASES_URL}
          target="_blank"
          rel="noopener"
          class="mt-4 text-center text-xs text-ink/70 underline-offset-2 hover:text-gold hover:underline"
          >Tüm sürümler (GitHub Releases)</a
        >
      </article>

      <!-- iOS kartı -->
      <article
        class="reveal flex flex-col rounded-2xl border border-white/5 bg-secondary p-8"
      >
        <div
          class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary text-gold"
        >
          <!-- Apple SVG Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-6 w-6"
            aria-hidden="true"
          >
            <path
              d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C3.8 16.32 3.1 9.88 7.02 5.92c.98-.98 2.15-1 3.03-.52 1.05.57 1.84.5 2.87 0 .84-.4 2.15-.55 3.1.4 1.25.9 2.05 2.2 2.45 3.97-2.6 1.1-2.2 4.63.4 5.75-.5 1.5-1.23 3.32-2.82 4.76M12.03 5.4c.12-2.26 1.88-4.22 3.98-4.4.24 2.4-1.92 4.62-3.98 4.4"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-extrabold text-ink-bright">iOS (iPhone)</h3>
        <p class="mt-2 text-sm text-ink">
          iOS cihazlar için uygulama paketi (Simulator / Sideloading).
        </p>

        <div class="mt-6 flex flex-col gap-3">
          <a
            href={iosHref}
            download
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-gold px-5 py-3 text-base font-bold text-primary transition-colors hover:bg-gold-soft"
          >
            .app indir (zip)
          </a>
        </div>
        <a
          href={LINKS.GITHUB_RELEASES_URL}
          target="_blank"
          rel="noopener"
          class="mt-4 text-center text-xs text-ink/70 underline-offset-2 hover:text-gold hover:underline"
          >Tüm sürümler (GitHub Releases)</a
        >
      </article>
    </div>
  </div>
</section>
