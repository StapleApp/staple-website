---
import { LINKS } from '../config';

const nav = [
  { href: '#ozellikler', label: 'Özellikler' },
  { href: '#ekranlar', label: 'Ekranlar' },
  { href: '#indir', label: 'İndir' },
  { href: '#sss', label: 'SSS' },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-primary/80 backdrop-blur"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6"
    aria-label="Ana menü"
  >
    <a href="#" class="flex items-center gap-2.5" aria-label="Staple ana sayfa">
      <img
        src="/staple-icon.png"
        alt="Staple logosu"
        width="36"
        height="36"
        class="h-9 w-9 rounded-lg"
      />
      <span class="text-lg font-extrabold tracking-tight text-ink-bright"
        >Staple</span
      >
    </a>

    <ul class="hidden items-center gap-7 md:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm font-medium text-ink transition-colors hover:text-gold"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <a
        href={LINKS.WEB_APP_URL}
        target="_blank"
        rel="noopener"
        class="hidden rounded-xl px-3.5 py-2 text-sm font-semibold text-ink-bright transition-colors hover:text-gold sm:inline-block"
      >
        Web’de Aç
      </a>
      <a
        href="#indir"
        class="rounded-xl bg-gold px-4 py-2 text-sm font-bold text-primary transition-colors hover:bg-gold-soft"
      >
        İndir
      </a>
    </div>
  </nav>
</header>
