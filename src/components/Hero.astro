---
import { LINKS, RELEASE } from '../config';

const windowsHref = RELEASE.windowsExe || LINKS.GITHUB_RELEASES_URL;
// Yerel dosya (public/) ise doğrudan indir; harici link ise yeni sekmede aç.
const isLocalExe = windowsHref.startsWith('/');
---

<section class="bg-tile relative overflow-hidden">
  <!-- Zeminden yumuşak altın parıltı -->
  <div
    class="pointer-events-none absolute -top-40 left-1/2 h-[520px] w-[820px] -translate-x-1/2 rounded-full bg-gold/10 blur-[120px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-primary/40 via-primary/60 to-primary"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto flex max-w-6xl flex-col items-center px-4 pb-20 pt-32 text-center sm:px-6 sm:pt-40"
  >
    <span
      class="reveal mb-6 inline-flex items-center gap-2 rounded-full border border-gold/30 bg-secondary/60 px-4 py-1.5 text-xs font-semibold text-gold"
    >
      <span class="h-2 w-2 rounded-full bg-gold"></span>
      Topluluğun, arkadaşların ve sohbetlerin tek çatı altında
    </span>

    <h1
      class="reveal max-w-4xl text-4xl font-extrabold leading-tight tracking-tight text-ink-bright sm:text-6xl"
    >
      Konuş. Sesli takıl. Ekran paylaş.
      <span class="text-gold-gradient">Hepsi tek yerde.</span>
    </h1>

    <p class="reveal mt-6 max-w-2xl text-lg text-ink sm:text-xl">
      Staple ile toplulukların, arkadaşların ve sohbetlerin tek çatı altında.
      Sunucular, ses/metin kanalları, birebir mesajlaşma ve ekran paylaşımı —
      hepsi hızlı ve düşük gecikmeli.
    </p>

    <div class="reveal mt-9 flex flex-col items-center gap-3 sm:flex-row">
      <a
        href={windowsHref}
        download={isLocalExe ? true : undefined}
        target={isLocalExe ? undefined : '_blank'}
        rel={isLocalExe ? undefined : 'noopener'}
        class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-gold px-7 py-3.5 text-base font-bold text-primary transition-colors hover:bg-gold-soft sm:w-auto"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="h-5 w-5"
          aria-hidden="true"
        >
          <path
            d="M12 3a1 1 0 0 1 1 1v9.59l3.3-3.3a1 1 0 1 1 1.4 1.42l-5 5a1 1 0 0 1-1.4 0l-5-5a1 1 0 1 1 1.4-1.42l3.3 3.3V4a1 1 0 0 1 1-1Zm-7 15a1 1 0 0 1 1 1v1h12v-1a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1Z"
          ></path>
        </svg>
        Windows için İndir
      </a>
      <a
        href={LINKS.WEB_APP_URL}
        target="_blank"
        rel="noopener"
        class="inline-flex w-full items-center justify-center gap-2 rounded-2xl border border-white/15 bg-secondary px-7 py-3.5 text-base font-semibold text-ink-bright transition-colors hover:border-gold/40 hover:text-gold sm:w-auto"
      >
        Web’de Aç
      </a>
    </div>

    <p class="reveal mt-4 text-sm text-ink/70">
      Windows 10/11 · {RELEASE.version} · {RELEASE.sizeWindows} · Ücretsiz
    </p>

    <!-- Banner önizleme -->
    <div class="reveal mt-14 w-full max-w-5xl">
      <div
        class="overflow-hidden rounded-2xl border border-white/10 bg-secondary/50 shadow-2xl shadow-black/40"
      >
        <img
          src="/profile-banner.png"
          alt="Staple uygulama arayüzü önizlemesi"
          width="1200"
          height="400"
          class="w-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
