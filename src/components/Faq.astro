---
const faqs = [
  {
    q: 'Staple ücretsiz mi?',
    a: 'Evet. Staple’ı indirmek ve kullanmak ücretsiz; sunucu kur, arkadaş ekle, sesli takıl.',
  },
  {
    q: 'Verilerim güvende mi?',
    a: 'Kimlik doğrulama ve veriler güvenli altyapı üzerinde (Supabase) tutulur, sesli sohbet WebRTC ile eşler arası taşınır. Yalnızca hesabın için gerekli verileri saklarız.',
  },
  {
    q: 'Hangi platformlarda çalışıyor?',
    a: 'Şu an Windows için masaüstü uygulaması (.exe/.msi) ve tüm modern tarayıcılarda çalışan web sürümü mevcut. macOS ve Linux yolda.',
  },
  {
    q: 'Hesap gerekiyor mu?',
    a: 'Evet, arkadaşlarını bulman ve sohbetlerinin senkron kalması için ücretsiz bir hesap oluşturman yeterli.',
  },
];
---

<section id="sss" class="relative py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2
        class="reveal text-3xl font-extrabold tracking-tight text-ink-bright sm:text-4xl"
      >
        Sık sorulan sorular
      </h2>
    </div>

    <div class="mt-12 space-y-3">
      {
        faqs.map((f) => (
          <details class="reveal group rounded-2xl border border-white/5 bg-secondary px-6 py-1 open:border-gold/30">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left text-lg font-semibold text-ink-bright marker:hidden">
              {f.q}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-5 w-5 flex-shrink-0 text-gold transition-transform group-open:rotate-45"
                aria-hidden="true"
              >
                <path d="M11 5a1 1 0 1 1 2 0v6h6a1 1 0 1 1 0 2h-6v6a1 1 0 1 1-2 0v-6H5a1 1 0 1 1 0-2h6V5Z" />
              </svg>
            </summary>
            <p class="pb-5 pr-8 text-base leading-relaxed text-ink">{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
