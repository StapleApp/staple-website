---
// Öne çıkan ekran görüntüleri. Görseller public/screenshots/ altına konur.
// Dosya adları: home.png, chat.png, voice.png (placeholder olarak hazır bırakıldı).
const shots = [
  {
    src: '/screenshots/home.png',
    title: 'Sunucu görünümü',
    desc: 'Kategoriler, kanallar ve üye listesiyle topluluğunun ana ekranı.',
  },
  {
    src: '/screenshots/chat.png',
    title: 'Mesajlaşma',
    desc: 'Yanıtla, düzenle, GIF ve emoji gönder; “yazıyor…” göstergesiyle canlı sohbet.',
  },
  {
    src: '/screenshots/voice.png',
    title: 'Sesli kanal & ekran paylaşımı',
    desc: 'Konuşma algılama, kişi bazlı ses seviyesi ve sistem sesli ekran paylaşımı.',
  },
];
---

<section id="ekranlar" class="bg-tile relative py-24">
  <div
    class="pointer-events-none absolute inset-0 bg-primary/70"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2
        class="reveal text-3xl font-extrabold tracking-tight text-ink-bright sm:text-4xl"
      >
        Nasıl görünüyor?
      </h2>
      <p class="reveal mt-4 text-lg text-ink">
        Tanıdık ama daha temiz bir arayüz. İşte Staple’ın öne çıkan ekranları.
      </p>
    </div>

    <div class="mt-14 space-y-10">
      {
        shots.map((s, i) => (
          <article
            class:list={[
              'reveal grid items-center gap-6 md:grid-cols-2 md:gap-10',
              i % 2 === 1 && 'md:[&>figure]:order-2',
            ]}
          >
            <figure class="overflow-hidden rounded-2xl border border-white/10 bg-secondary shadow-2xl shadow-black/40">
              {/* Placeholder: gerçek görsel eklenene kadar zarif bir yer tutucu */}
              <div class="relative aspect-video w-full">
                <img
                  src={s.src}
                  alt={s.title}
                  loading="lazy"
                  class="h-full w-full object-cover"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <div
                  class="absolute inset-0 hidden flex-col items-center justify-center gap-3 bg-secondary text-ink"
                  aria-hidden="true"
                >
                  <img
                    src="/staple-icon.png"
                    alt=""
                    width="48"
                    height="48"
                    class="h-12 w-12 opacity-60"
                  />
                  <span class="text-sm font-medium">
                    Ekran görüntüsü yakında
                  </span>
                  <code class="rounded bg-primary px-2 py-1 text-xs text-gold">
                    {s.src}
                  </code>
                </div>
              </div>
            </figure>

            <div>
              <span class="text-sm font-bold uppercase tracking-wider text-gold">
                0{i + 1}
              </span>
              <h3 class="mt-2 text-2xl font-extrabold text-ink-bright">
                {s.title}
              </h3>
              <p class="mt-3 text-base leading-relaxed text-ink">{s.desc}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
